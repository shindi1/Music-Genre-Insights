# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit it.
#
# These are ONLY needed to run scripts/scrape_supplemental.py to fill
# underrepresented genres from the Genius API. The main pipeline runs
# entirely from local Kaggle CSVs and needs none of these.

# Genius API — free, ~5 min to get a token at https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=your_genius_access_token_here

# Spotify Web API — note that as of Nov 2024 audio_features / recommendations /
# related_artists are dead for new apps. We only use search + artist endpoints.
# Register at https://developer.spotify.com/dashboard
SPOTIPY_CLIENT_ID=your_spotify_client_id_here
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret_here
